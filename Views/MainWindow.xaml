<Window x:Class="Jaezoo.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jaezoo — Chat" Height="640" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <!-- Друзья/заявки -->
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
            <!-- Чат -->
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="320"/>
            <!-- Поиск -->
        </Grid.ColumnDefinitions>

        <!-- FRIENDS -->
        <DockPanel Grid.Column="0" Margin="8">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Друзья" FontWeight="Bold" Margin="0,0,0,6"/>
                <Button Content="Обновить" Command="{Binding RefreshAllCmd}" Width="100"/>
            </StackPanel>

            <ListBox ItemsSource="{Binding Friends.Friends}" Margin="0,8,0,0"
                     DisplayMemberPath="Display"
                     SelectedItem="{Binding Chat.SelectedPeer}">
            </ListBox>

            <Expander Header="Входящие заявки" IsExpanded="True" Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding Friends.Incoming}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Display}" Width="160"/>
                                <Button Content="Принять" Width="70"
                                        Command="{Binding DataContext.Friends.AcceptCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"/>
                                <Button Content="Отклонить" Width="70" Margin="4,0,0,0"
                                        Command="{Binding DataContext.Friends.DeclineCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Исходящие заявки" IsExpanded="False" Margin="0,8,0,0">
                <ListBox ItemsSource="{Binding Friends.Outgoing}" DisplayMemberPath="Display"/>
            </Expander>
        </DockPanel>

        <!-- CHAT -->
        <DockPanel Grid.Column="2" Margin="8">
            <TextBlock DockPanel.Dock="Top" FontWeight="Bold" FontSize="14"
                       Text="{Binding Chat.SelectedPeer.Display, TargetNullValue='Выберите собеседника'}"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Chat.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="6" CornerRadius="4" Background="#eee">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="DimGray">
                                        <Run Text="{Binding SenderId}" />
                                        <Run Text=" → " /><Run Text="{Binding RecipientId}"/>
                                        <Run Text="  ·  "/>
                                        <Run Text="{Binding CreatedAtUtc}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <DockPanel DockPanel.Dock="Bottom">
                <TextBox Text="{Binding Chat.Outgoing, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" AcceptsReturn="True" Height="60"/>
                <Button Content="Отправить" Width="100" VerticalAlignment="Bottom" Command="{Binding Chat.SendCmd}"/>
            </DockPanel>
        </DockPanel>

        <!-- SEARCH -->
        <DockPanel Grid.Column="4" Margin="8">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Поиск пользователей" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBox Width="200" Text="{Binding Search.Query, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Найти" Margin="6,0,0,0" Command="{Binding Search.SearchCmd}"/>
                </StackPanel>
            </StackPanel>

            <ListBox Margin="0,8,0,0" ItemsSource="{Binding Search.Results}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock FontWeight="Bold" Text="{Binding Display}"/>
                                <TextBlock Foreground="Gray" FontSize="12" Text="{Binding Login}"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Content="Добавить" Width="80"
                                    Command="{Binding DataContext.Search.AddFriendCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Id}"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
